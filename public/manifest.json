{
    "name": "Post for nostter",
    "short_name": "Post for nostter",
    "manifest_version": 3,
    "version": "0.0.4",
    "description": "nostterで現在開いているページをポストするページを開く拡張です。使用にはnostterのログインが必要です。",
    "action": {
        "default_title": "Post for nostter"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "tabs",
        "contextMenus",
        "storage"
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "icons": {
        "128": "post_for_nostter_128.png"
    }
}
